{
  "name": "myblog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/generate-static-content-registry.mjs",
    "build": "next build --webpack",
    "cf:build": "node scripts/generate-static-content-registry.mjs && opennextjs-cloudflare build",
    "cf:deploy": "node scripts/generate-static-content-registry.mjs && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:preview": "node scripts/generate-static-content-registry.mjs && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "start": "next start",
    "test": "node --experimental-specifier-resolution=node --test --experimental-strip-types src/lib/*.test.mjs",
    "lint": "eslint .",
    "typecheck": "node -e \"require('node:fs').rmSync('.next/types',{recursive:true,force:true}); require('node:fs').rmSync('.next/dev/types',{recursive:true,force:true})\" && next typegen && node scripts/sync-next-typegen.mjs && tsc --noEmit --incremental false"
  },
  "dependencies": {
    "@next/mdx": "16.2.3",
    "@opennextjs/cloudflare": "^1.19.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.7.0",
    "next": "16.2.3",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.85.0"
  }
}
